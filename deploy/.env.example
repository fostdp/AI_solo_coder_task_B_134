# =============================================
# 环境变量示例文件
# 使用: cp .env.example .env 然后修改密码
# =============================================

# =============================================
# 数据库密码 (必填)
# =============================================
DB_PASSWORD=armillary_secure_password_2026

# =============================================
# MQTT密码 (必填)
# =============================================
MQTT_PASSWORD=armillary_mqtt_secure_2026

# =============================================
# 端口映射 (可选，按需修改)
# =============================================
BACKEND_PORT=8080
FRONTEND_PORT=80
DB_PORT=5432
MQTT_PORT=1883

# =============================================
# 模拟器配置 (启动simulator profile时生效)
# =============================================
SIMULATOR_MODE=normal
SIMULATOR_SPEED_FACTOR=1.0
SIMULATOR_LOAD_FACTOR=1.0
SIMULATOR_INTERVAL_SECONDS=60
